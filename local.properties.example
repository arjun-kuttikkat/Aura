# Copy this file to local.properties and fill in your values.
# local.properties is git-ignored — never commit real keys.

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Groq AI (Vision + Chat)
# Get key at https://console.groq.com
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Solana / Helius RPC
# Get key at https://helius.dev
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# Platform wallets (Base58 encoded)
# TREASURY_WALLET: The public key for fee collection
TREASURY_WALLET=your-treasury-wallet-base58
# SOLANA_AUTHORITY_KEY: The PRIVATE key for the platform authority wallet
SOLANA_AUTHORITY_KEY=your-authority-private-key-base58

# Optional: Google Maps SDK for Android
# Get key at https://console.cloud.google.com
MAPS_API_KEY=your-maps-api-key
