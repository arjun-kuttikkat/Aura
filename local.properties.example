# Copy this file to local.properties and fill in your values.
# local.properties is git-ignored — never commit real keys.

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key

# Groq AI (Vision + Chat) — meta-llama/llama-4-scout-17b-16e-instruct
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Solana / Helius RPC (use full URL or API key)
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
# Or: HELIUS_API_KEY=your-helius-api-key

# Platform wallets (required for escrow)
TREASURY_WALLET=your-treasury-wallet-base58
RELEASE_AUTHORITY_PUBKEY=your-release-authority-pubkey-base58
# Fallback: SOLANA_AUTHORITY_KEY=... (used if RELEASE_AUTHORITY_PUBKEY unset)

# Auth
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Optional
CEREBRAS_API_KEY=
MAPS_API_KEY=
